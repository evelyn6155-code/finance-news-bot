# 复制这个文件为 .env，填入你自己的值。切勿把 .env 提交到 git。

# --- DeepSeek（AI 改写）---
# 在 https://platform.deepseek.com 创建 API key，粘贴到这里
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# 一般不用改：deepseek-chat 就是 V3，适合改写任务
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- 邮件 SMTP ---
# QQ邮箱：smtp.qq.com  端口465
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的邮箱@qq.com
# 注意：这里填“授权码”，不是邮箱登录密码！
SMTP_PASSWORD=你的授权码
# 收件邮箱，不填默认发给自己
MAIL_TO=你的邮箱@qq.com
